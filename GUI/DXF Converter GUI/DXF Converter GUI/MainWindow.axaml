<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DXF_Converter_GUI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="640"
        x:Class="DXF_Converter_GUI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1200" Height="680" MinWidth="920" MinHeight="540"
        Title="DXF → SVG → PNG Converter">

    <Window.Styles>
        <!-- Transition column: an arrow and the controls that drive one conversion. -->
        <Style Selector="StackPanel.transition">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Spacing" Value="8" />
            <Setter Property="Width" Value="140" />
        </Style>
        <Style Selector="StackPanel.transition > TextBlock.arrow">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>
        <Style Selector="Border.node">
            <Setter Property="BorderBrush" Value="#40808080" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="Border.preview">
            <Setter Property="Background" Value="#10808080" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="16">

        <TextBlock DockPanel.Dock="Top" Text="DXF → SVG → PNG Pipeline"
                   FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top"
                   Text="Each stage is a node you can upload into and preview; the arrows between them convert one format to the next."
                   Opacity="0.7" Margin="0,0,0,12" TextWrapping="Wrap" />

        <Border DockPanel.Dock="Bottom" Background="#20808080" CornerRadius="4"
                Padding="10,6" Margin="0,12,0,0">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
        </Border>

        <!-- node | transition | node | transition | node -->
        <Grid ColumnDefinitions="*,Auto,*,Auto,*">

            <!-- Node 1: DXF -->
            <Border Grid.Column="0" Classes="node">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="8">
                        <TextBlock Text="DXF" FontSize="16" FontWeight="SemiBold" />
                        <Button Content="Upload DXF…" Click="OnLoadDxf" HorizontalAlignment="Stretch" />
                        <TextBlock Text="{Binding DxfFileName, StringFormat='File: {0}', FallbackValue='No DXF loaded'}"
                                   Opacity="0.7" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="DXF preview" Opacity="0.7" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border Classes="preview">
                        <Image Source="{Binding DxfPreview}" Stretch="Uniform" Margin="8" />
                    </Border>
                </DockPanel>
            </Border>

            <!-- Transition: DXF -> SVG -->
            <StackPanel Grid.Column="1" Classes="transition">
                <TextBlock Classes="arrow" Text="→" />
                <TextBlock Text="DXF → SVG" HorizontalAlignment="Center" FontWeight="SemiBold" />
                <StackPanel Spacing="2">
                    <TextBlock Text="Fill color" Opacity="0.7" FontSize="12" />
                    <TextBox Text="{Binding FillColor}" />
                </StackPanel>
                <Button Content="Convert" Click="OnConvertToSvg"
                        HorizontalAlignment="Stretch" IsEnabled="{Binding CanConvertToSvg}" />
            </StackPanel>

            <!-- Node 2: SVG -->
            <Border Grid.Column="2" Classes="node">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="8">
                        <TextBlock Text="SVG" FontSize="16" FontWeight="SemiBold" />
                        <Button Content="Upload SVG…" Click="OnLoadSvg" HorizontalAlignment="Stretch" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Rotate 90° CW" Click="OnRotateSvg"
                                    IsEnabled="{Binding HasSvg}" />
                            <Button Content="Download…" Click="OnDownloadSvg"
                                    IsEnabled="{Binding HasSvg}" />
                        </StackPanel>
                        <TextBlock Text="SVG preview" Opacity="0.7" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border Classes="preview">
                        <Image Source="{Binding SvgPreview}" Stretch="Uniform" Margin="8" />
                    </Border>
                </DockPanel>
            </Border>

            <!-- Transition: SVG -> PNG -->
            <StackPanel Grid.Column="3" Classes="transition">
                <TextBlock Classes="arrow" Text="→" />
                <TextBlock Text="SVG → PNG" HorizontalAlignment="Center" FontWeight="SemiBold" />
                <StackPanel Spacing="2">
                    <TextBlock Text="Width (px)" Opacity="0.7" FontSize="12" />
                    <NumericUpDown Value="{Binding PngWidth}" Minimum="1" Maximum="20000"
                                   Increment="1" FormatString="0" />
                </StackPanel>
                <Button Content="Convert" Click="OnConvertToPng"
                        HorizontalAlignment="Stretch" IsEnabled="{Binding CanConvertToPng}" />
            </StackPanel>

            <!-- Node 3: PNG -->
            <Border Grid.Column="4" Classes="node">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="8">
                        <TextBlock Text="PNG" FontSize="16" FontWeight="SemiBold" />
                        <Button Content="Upload PNG…" Click="OnLoadPng" HorizontalAlignment="Stretch" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Rotate 90° CW" Click="OnRotatePng"
                                    IsEnabled="{Binding HasPng}" />
                            <Button Content="Download…" Click="OnDownloadPng"
                                    IsEnabled="{Binding HasPng}" />
                        </StackPanel>
                        <TextBlock Text="PNG preview" Opacity="0.7" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border Classes="preview">
                        <Image Source="{Binding PngPreview}" Stretch="Uniform" Margin="8" />
                    </Border>
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
