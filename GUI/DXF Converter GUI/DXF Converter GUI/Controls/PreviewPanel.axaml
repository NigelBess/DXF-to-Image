<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DXF_Converter_GUI.ViewModels"
             x:Class="DXF_Converter_GUI.Controls.PreviewPanel"
             x:DataType="vm:IPreviewNode">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Rotate 90° CW" Click="OnRotate" IsEnabled="{Binding CanRotate}" />
                <Button Content="Download…" Click="OnDownload" IsEnabled="{Binding HasArtifact}" />
            </StackPanel>
            <TextBlock Text="{Binding FileName, StringFormat='File: {0}'}"
                       IsVisible="{Binding HasArtifact}"
                       Opacity="0.7" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Title, StringFormat='{}{0} preview'}"
                       Opacity="0.7" Margin="0,4,0,0" />
        </StackPanel>
        <Border Background="#10808080" CornerRadius="4" Margin="0,6,0,0">
            <Image Source="{Binding Preview}" Stretch="Uniform" Margin="8" />
        </Border>
    </DockPanel>
</UserControl>
